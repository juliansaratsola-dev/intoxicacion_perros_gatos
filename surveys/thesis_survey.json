{
  "title": "Encuesta de tesis - Intoxicación en animales pequeños",
  "description": "Recopilación de datos sobre casos de intoxicación en perros y gatos. Responda con la mayor precisión posible. Datos personales son opcionales y solo para seguimiento si autoriza.",
  "questions": [
    {"name": "owner_name", "type": "text", "label": "Nombre del propietario (opcional)", "required": false},
    {"name": "contact_email", "type": "text", "label": "Correo electrónico (opcional)", "required": false, "validation": {"pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"}},
    {"name": "respondent_anonymous", "type": "radio", "label": "¿Desea permanecer anónimo?", "options": ["SI", "NO"], "required": true},
    {"name": "allow_contact", "type": "radio", "label": "¿Autoriza que lo contactemos si necesitamos aclaraciones?", "options": ["SI", "NO"], "required": true},
    {"name": "species", "type": "select", "label": "Especie", "options": ["Perro", "Gato", "Otro"], "required": true},
    {"name": "species_other", "type": "text", "label": "Especifique otra especie", "required": false, "showIf": {"species": "Otro"}},
    {"name": "age_years", "type": "text", "label": "Edad (años)", "required": false},
    {"name": "weight_kg", "type": "text", "label": "Peso aproximado (kg)", "required": false, "validation": {"type": "number", "min": 0}},
    {"name": "exposure_date", "type": "text", "label": "Fecha/hora aproximada de la exposición", "required": false},
    {"name": "substance_known", "type": "radio", "label": "¿Sabe qué sustancia estuvo involucrada?", "options": ["SI", "NO"], "required": true},
    {"name": "substance_name", "type": "text", "label": "Nombre de la sustancia (si conoce)", "required": false, "showIf": {"substance_known": "SI"}},
    {"name": "exposure_route", "type": "select", "label": "Vía de exposición", "options": ["Oral", "Cutánea", "Inhalación", "Ocular", "Otra"], "required": true},
    {"name": "exposure_route_other", "type": "text", "label": "Otra vía (especifique)", "required": false, "showIf": {"exposure_route": "Otra"}},
    {"name": "amount_estimated", "type": "text", "label": "Cantidad aproximada ingerida/explicación (si aplica)", "required": false},

    {"name": "vomiting", "type": "radio", "label": "¿Presenta vómitos?", "options": ["SI", "NO"], "required": true},
    {"name": "diarrhea", "type": "radio", "label": "¿Presenta diarrea?", "options": ["SI", "NO"], "required": true},
    {"name": "convulsions", "type": "radio", "label": "¿Ha tenido convulsiones?", "options": ["SI", "NO"], "required": true},
    {"name": "respiratory_distress", "type": "radio", "label": "¿Presenta dificultad respiratoria?", "options": ["SI", "NO"], "required": true},
    {"name": "other_symptoms", "type": "textarea", "label": "Descripción de otros síntomas (si los hay)", "required": false},

    {"name": "time_since_exposure_hours", "type": "text", "label": "Tiempo transcurrido desde la exposición (horas)", "required": false, "showIf": {"vomiting": "SI"}, "validation": {"type": "number", "min": 0}},

    {"name": "first_aid_given", "type": "radio", "label": "¿Se realizó alguna medida de primeros auxilios en casa?", "options": ["SI", "NO"], "required": true},
    {"name": "first_aid_desc", "type": "textarea", "label": "Describa la medida tomada", "required": false, "showIf": {"first_aid_given": "SI"}},

    {"name": "went_to_vet", "type": "radio", "label": "¿Llevó al animal al veterinario?", "options": ["SI", "NO"], "required": true},
    {"name": "vet_treatment", "type": "textarea", "label": "Tratamientos realizados por el veterinario (si aplica)", "required": false, "showIf": {"went_to_vet": "SI"}},
    {"name": "outcome", "type": "select", "label": "Estado final conocido", "options": ["Recuperado", "En tratamiento", "Fallecido", "Desconocido"], "required": true},

    {"name": "consent_data_use", "type": "radio", "label": "¿Autoriza el uso de los datos de forma anónima en la tesis/publicaciones?", "options": ["SI", "NO"], "required": true},
    {"name": "comments", "type": "textarea", "label": "Comentarios adicionales", "required": false},
    {"name": "contact_email", "type": "text", "label": "Correo electrónico (opcional)", "required": false, "validation": {"pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"}}
  ]
}
