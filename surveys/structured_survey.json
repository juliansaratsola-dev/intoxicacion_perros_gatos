{
  "title": "Encuesta de tesis - Intoxicación en animales pequeños",
  "description": "Recopilación de datos sobre casos de intoxicación en perros, gatos y animales no tradicionales en Uruguay. Responda con la mayor precisión posible. Los datos serán utilizados exclusivamente con fines académicos y de investigación.",
  "sections": [
    {
      "title": "Datos Generales",
      "description": "Por favor, complete los datos generales de su clínica veterinaria.",
      "questions": [
        {
          "name": "clinic_name",
          "type": "text",
          "label": "Nombre de la Clínica Veterinaria",
          "required": true
        },
        {
          "name": "responsible_vet",
          "type": "text",
          "label": "Veterinario/a responsable (opcional)",
          "required": false
        },
        {
          "name": "phone",
          "type": "text",
          "label": "Teléfono",
          "required": true
        },
        {
          "name": "email",
          "type": "text",
          "label": "Correo electrónico",
          "required": true,
          "validation": {
            "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
          }
        },
        {
          "name": "address",
          "type": "text",
          "label": "Dirección",
          "required": true
        },
        {
          "name": "start_year",
          "type": "number",
          "label": "Año de inicio",
          "required": true
        },
        {
          "name": "weekly_patients",
          "type": "select",
          "label": "N° pacientes semanal",
          "options": ["pequeña (<20 pacientes)", "mediano (20-50 pacientes)", "grande (>50 pacientes)"],
          "required": true
        }
      ]
    }
  ]
}